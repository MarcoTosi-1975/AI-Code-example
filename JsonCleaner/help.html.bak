        .badge-input { background: #bee3f8; color: #2c5282; }
        .badge-output { background: #c6f6d5; color: #22543d; }
        .badge-optional { background: #fed7d7; color: #742a2a; }
        .badge-new { background: #fef3c7; color: #92400e; }

        .example {
            background: #fffbeb;
